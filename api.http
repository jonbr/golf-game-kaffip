@baseUrl = http://localhost:8080

### ---------------------------------------
### Health Check
### ---------------------------------------
GET {{baseUrl}}/health


### ---------------------------------------
### Create Player
### ---------------------------------------
POST {{baseUrl}}/players
Content-Type: application/json

{
  "name": "Player-new-4",
  "handicap": 40.1
}


### ---------------------------------------
### Get All Players
### ---------------------------------------
GET {{baseUrl}}/players


### ---------------------------------------
### Get Player By ID
### ---------------------------------------
GET {{baseUrl}}/players/5


### ---------------------------------------
### Update Player
### ---------------------------------------
PUT {{baseUrl}}/players/1
Content-Type: application/json

{
  "name": "Player-1-modified",
  "handicap": 4.4
}


### ---------------------------------------
### Delete Player (soft)
### ---------------------------------------
DELETE {{baseUrl}}/players/1


### ---------------------------------------
### Create Game
### variant: "gross" (handicap surplus at start, no per-hole strokes)
###       or "net" (full per-hole handicap strokes, except birdies/eagles)
### ---------------------------------------
POST {{baseUrl}}/games
Content-Type: application/json

{
  "course_id": "13fae2ba-51cf-436d-93da-2faa8cecc2c9",
  "team_a": [1, 2],
  "team_b": [3, 4],
  "variant": "gross"
}


### ---------------------------------------
### Get Games
### optional ?status=active|finished
### ---------------------------------------
GET {{baseUrl}}/games?status=finished


### ---------------------------------------
### Get Game
### ---------------------------------------
GET {{baseUrl}}/games/game_1783519378063754000


### ---------------------------------------
### Submit Hole Score
### Must target holeNumber <= CurrentHole. Scoring the current hole
### advances CurrentHole by one; scoring any earlier hole is treated
### as a correction and does not move CurrentHole.
### ---------------------------------------
PUT {{baseUrl}}/games/game_1784036476579441000/holes/2/score
Content-Type: application/json

{
  "scores": [
    { "player_id": 1, "gross": 5 },
    { "player_id": 2, "gross": 4 },
    { "player_id": 3, "gross": 5 },
    { "player_id": 4, "gross": 4 }
  ]
}


### ---------------------------------------
### Correct an Earlier Hole
### Re-submitting a lower hole number than CurrentHole is a full
### correction: the stored result is replaced and the match score is
### recomputed by replaying every hole from 1 through CurrentHole.
### ---------------------------------------
PUT {{baseUrl}}/games/game_1784036476579441000/holes/1/score
Content-Type: application/json

{
  "scores": [
    { "player_id": 1, "gross": 4 },
    { "player_id": 2, "gross": 8 },
    { "player_id": 3, "gross": 4 },
    { "player_id": 4, "gross": 6 }
  ]
}


### ---------------------------------------
### Finish Game
### ---------------------------------------
POST {{baseUrl}}/games/game_1784029805139758000/finish